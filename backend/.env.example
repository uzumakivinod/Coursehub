# Server
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL=3600

# CORS
FRONTEND_URL=http://localhost:3000

# MongoDB (optional, for persistent storage)
MONGODB_URI=mongodb://localhost:27017/freecoursedb

# Worker API key (internal)
WORKER_API_KEY=change_this_secret_key_in_production
