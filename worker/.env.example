NODE_ENV=production
LOG_LEVEL=info

# Backend API
BACKEND_URL=http://backend:5000
WORKER_API_KEY=change_this_secret_key_in_production

# Optional: YouTube Data API v3 (free tier: 10,000 units/day)
# Get at: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# Cron schedule (default: 3am UTC daily)
CRON_SCHEDULE=0 3 * * *
