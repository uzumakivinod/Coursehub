# ── FreeCourseHub — Root .env ────────────────────────────
# Copy this to .env and fill in values
# cp .env.example .env

# ── Backend ───────────────────────────────────────────────
NODE_ENV=production
PORT=5000
LOG_LEVEL=info

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL=3600

# CORS
FRONTEND_URL=http://localhost

# Security
WORKER_API_KEY=change_this_in_production_use_openssl_rand_hex_32

# ── Worker ────────────────────────────────────────────────
BACKEND_URL=http://nginx/api
# Optional: Get free API key at https://console.cloud.google.com
YOUTUBE_API_KEY=

# ── Frontend ──────────────────────────────────────────────
VITE_API_URL=/api
